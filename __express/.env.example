# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
# Get these values from Firebase Console → Project Settings → Service Accounts
# Click "Generate new private key" to download the JSON file with all these values

# Your Firebase project ID (e.g., "my-app-12345")
FIREBASE_PROJECT_ID=your-project-id

# IMPORTANT: The private key must include \n for newlines and be wrapped in quotes
# Copy the entire private_key value from your service account JSON
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Private key ID from service account JSON
FIREBASE_PRIVATE_KEY_ID=your-private-key-id

# Client email from service account JSON (e.g., firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com)
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Client ID from service account JSON (numeric string)
FIREBASE_CLIENT_ID=123456789012345678901

# ============================================================================
# API SECURITY
# ============================================================================
# Generate a strong, random API key (minimum 32 characters)
# Run this command to generate one:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 
# CRITICAL: This same key must be used in your PocketBase helper file!
API_SECRET_KEY=your_super_secure_random_string_at_least_32_characters_long

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins (your PocketBase URL and any other domains)
# Examples:
# - Development: http://localhost:8090
# - Production: https://your-pocketbase-domain.com
# - Multiple: https://pb.example.com,https://app.example.com
ALLOWED_ORIGINS=http://localhost:8090,https://your-pocketbase-domain.com

# ============================================================================
# SERVER CONFIGURATION (Optional - for local development)
# ============================================================================
# Port for local development (Vercel ignores this in production)
PORT=3000

# Environment (development, production, test)
NODE_ENV=development
